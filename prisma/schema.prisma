generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Article {
  id           Int          @id @default(autoincrement())
  title        String       @db.VarChar(500)
  slug         String       @unique @db.VarChar(500)
  topic        String?      @db.VarChar(500)
  backlinks    Json?
  image        String?      @db.VarChar(1000)
  content      String       @db.LongText
  blocks       Json
  language     String       @default("en") @db.VarChar(10)
  published_at DateTime?
  status       String       @default("draft") @db.VarChar(20)
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  category_id  Int?
  author_id    Int?
  site_id      Int?
  author       Author?      @relation(fields: [author_id], references: [id])
  category     Category?    @relation(fields: [category_id], references: [id])
  site         Site?        @relation(fields: [site_id], references: [id])
  meta         ArticleMeta?

  @@index([status])
  @@index([language])
  @@index([published_at])
  @@index([author_id], map: "Article_author_id_fkey")
  @@index([category_id], map: "Article_category_id_fkey")
  @@index([site_id], map: "Article_site_id_fkey")
}

model ArticleMeta {
  id               Int     @id @default(autoincrement())
  article_id       Int     @unique
  page_title       String? @db.VarChar(500)
  meta_title       String? @db.VarChar(500)
  meta_keywords    String? @db.VarChar(1000)
  meta_description String? @db.VarChar(500)
  article          Article @relation(fields: [article_id], references: [id], onDelete: Cascade)
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(200)
  slug     String    @unique @db.VarChar(200)
  color    String?   @db.VarChar(50)
  articles Article[]
}

model Author {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(200)
  image    String?   @db.VarChar(1000)
  bio      String?   @db.Text
  articles Article[]
}

model Site {
  id         Int       @id @default(autoincrement())
  name       String    @db.VarChar(200)
  domain     String    @unique @db.VarChar(200)
  api_key    String    @unique @db.VarChar(100)
  created_at DateTime  @default(now())
  ai_persona String?   @db.Text
  articles   Article[]
  banners    Banner[]
}

model Banner {
  id         Int      @id @default(autoincrement())
  site_id    Int
  type       String   @db.VarChar(10) // "X" or "Y"
  name       String?  @db.VarChar(200)
  image_url  String   @db.VarChar(1000)
  link_url   String?  @db.VarChar(1000)
  status     String   @default("active") @db.VarChar(20)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  site       Site     @relation(fields: [site_id], references: [id])

  @@index([site_id])
  @@index([type])
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique @db.VarChar(255)
  password   String   @db.VarChar(255)
  name       String?  @db.VarChar(255)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}
